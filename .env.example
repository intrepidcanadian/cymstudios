# WalletConnect (get from https://cloud.reown.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Supabase Database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# x402 Payment - Facilitator Wallet
FACILITATOR_PRIVATE_KEY=your_facilitator_wallet_private_key
# Optional: separate key for mainnet
# FACILITATOR_MAINNET_PRIVATE_KEY=

# x402 Payment - Ethereum Mainnet
ETHEREUM_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# x402 Payment - Base (USDC, low gas)
BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# x402 Payment - Conflux eSpace (USDT0)
CONFLUX_ESPACE_RPC_URL=https://evm.confluxrpc.com
NEXT_PUBLIC_CONFLUX_RPC_URL=https://evm.confluxrpc.com

# xRemit Gift Card Provider
EXTERNAL_API_KEY=your_xremit_api_key
EXTERNAL_CLIENT_SECRET=your_xremit_client_secret
XREMIT_ENV=production

# Webhook security (REQUIRED — webhook auth is mandatory)
XREMIT_WEBHOOK_API_KEY=your_webhook_secret

# Exchange Rates (API Layer)
API_LAYER_KEY=your_apilayer_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@cymstudio.app

# App URL (for webhook callbacks)
NEXT_PUBLIC_API_URL=https://cymstudio.app

# OSL Pay Onramp (optional — leave blank to disable the onramp page)
# Point NEXT_PUBLIC_SERVER_URL at your own onramp backend (the OSL Pay integration server).
NEXT_PUBLIC_SERVER_URL=
NEXT_PUBLIC_OSL_WEBHOOK_URL=
NEXT_PUBLIC_OSL_APP_ID=your_osl_app_id
NEXT_PUBLIC_OSL_SUCCESS_URL=https://cymstudio.app/onramp?status=success
NEXT_PUBLIC_OSL_FAIL_URL=https://cymstudio.app/onramp?status=fail
