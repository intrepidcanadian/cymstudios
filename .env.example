# Privy Authentication (get from https://privy.io/dashboard)
PRIVY_APP_ID=your_privy_app_id_here

# Supabase Database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# x402 Payment - Ethereum Mainnet
FACILITATOR_PRIVATE_KEY=your_facilitator_wallet_private_key
ETHEREUM_MAINNET_RPC_URL=https://eth.llamarpc.com

# xRemit Gift Card Provider
EXTERNAL_API_KEY=your_xremit_api_key
EXTERNAL_CLIENT_SECRET=your_xremit_client_secret
XREMIT_ENV=production

# Webhook security (optional)
XREMIT_WEBHOOK_API_KEY=your_webhook_secret

# Exchange Rates (API Layer)
API_LAYER_KEY=your_apilayer_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@cymstudio.com

# App URL (for webhook callbacks)
NEXT_PUBLIC_API_URL=https://cymstudio.com

# OSL Pay Onramp (Heroku backend)
NEXT_PUBLIC_SERVER_URL=https://gswap-server-04651a4e88ed.herokuapp.com
NEXT_PUBLIC_OSL_APP_ID=your_osl_app_id
NEXT_PUBLIC_OSL_SUCCESS_URL=https://cymstudio.com/onramp?status=success
NEXT_PUBLIC_OSL_FAIL_URL=https://cymstudio.com/onramp?status=fail
